# ToxiLens Platform Environment Configuration

# ============================================================================
# API Configuration
# ============================================================================

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Maximum batch size for batch predictions
MAX_BATCH_SIZE=1000

# ============================================================================
# Model Configuration
# ============================================================================

# Path to model artifacts directory
MODEL_ARTIFACTS_PATH=./ml/artifacts

# Device for model inference (cpu, cuda, mps)
DEVICE=cpu

# ============================================================================
# LLM API Keys (for report generation)
# ============================================================================

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key (alternative)
GROQ_API_KEY=your_groq_api_key_here

# Mistral API Key (alternative)
MISTRAL_API_KEY=your_mistral_api_key_here

# Preferred LLM provider (anthropic, groq, mistral)
LLM_PROVIDER=anthropic

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log format (json, console)
LOG_FORMAT=json

# ============================================================================
# Security Configuration
# ============================================================================

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=10

# Enable/disable API documentation endpoints
ENABLE_DOCS=true

# ============================================================================
# Performance Configuration
# ============================================================================

# Number of workers for batch processing
NUM_WORKERS=4

# Enable model caching
ENABLE_MODEL_CACHE=true

# ============================================================================
# Feature Flags
# ============================================================================

# Enable conformal prediction
ENABLE_CONFORMAL_PREDICTION=true

# Enable SHAP explainability
ENABLE_SHAP=true

# Enable Captum explainability
ENABLE_CAPTUM=true

# Enable structural alerts
ENABLE_STRUCTURAL_ALERTS=true

# Enable ADMET predictions
ENABLE_ADMET=true

# Enable UMAP chemical space search
ENABLE_UMAP_SEARCH=true

# Enable bioisostere generation
ENABLE_BIOISOSTERE_GENERATION=true

# Enable LLM report generation
ENABLE_LLM_REPORTS=true

# Enable PDF export
ENABLE_PDF_EXPORT=true
